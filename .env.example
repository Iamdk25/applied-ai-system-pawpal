# Copy this file to `.env` and fill in your real values. Do NOT commit `.env`.

# Provider keys: set either GEMINI_API_KEY (Google Gemini) or ANTHROPIC_API_KEY.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides
PAWPAL_AGENT_MODEL=claude-sonnet-4-6
PAWPAL_AGENT_LOG_LEVEL=INFO
